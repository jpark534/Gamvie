<!DOCTYPE html>
<html>
  <head>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎬</text></svg>">
    <title>Gamvie</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; cursor: none; }
      body { background: #12172b; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }

      #cursor {
        position: fixed;
        pointer-events: none;
        z-index: 9999;
        font-size: 20px;
        transform: translate(-50%, -50%);
        top: -40px;
        left: -40px;
      }

      nav {
        background: rgba(255,255,255,0.03);
        border-bottom: 0.5px solid rgba(255,255,255,0.07);
        padding: 14px 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .nav-logo { color: #fff; font-size: 15px; font-weight: 500; text-decoration: none; }

      .reel-hole {
        width: 5px; height: 5px; border-radius: 1px;
        background: #c0392b; opacity: 0.7;
        animation: blink 1.8s infinite;
        display: inline-block;
      }
      .reel-hole:nth-child(2) { animation-delay: 0.3s; }
      .reel-hole:nth-child(3) { animation-delay: 0.6s; }
      .reel-hole:nth-child(4) { animation-delay: 0.9s; }
      @keyframes blink { 0%,100% { opacity: 0.7; } 50% { opacity: 0.2; } }

      .mood-input-box {
        background: rgba(255,255,255,0.04);
        border: 0.5px solid rgba(255,255,255,0.09);
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 12px;
        transition: border-color 0.2s ease, background 0.2s ease;
      }
      .mood-input-box:focus-within {
        border-color: rgba(192,57,43,0.4);
        background: rgba(255,255,255,0.06);
      }
      .mood-input-box textarea {
        background: transparent;
        border: none;
        outline: none;
        width: 100%;
        color: rgba(255,255,255,0.85);
        font-size: 14px;
        line-height: 1.7;
        resize: none;
        font-family: inherit;
      }
      .mood-input-box textarea::placeholder { color: rgba(255,255,255,0.2); }

      input[type=submit], .find-btn {
        background: #c0392b;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 12px 24px;
        font-size: 14px;
        font-weight: 500;
        cursor: none;
        position: relative;
        overflow: hidden;
        transition: transform 0.15s ease, background 0.2s ease, box-shadow 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      input[type=submit]:hover, .find-btn:hover {
        background: #a93226;
        transform: translateY(-2px);
        box-shadow: 0 6px 24px rgba(192,57,43,0.4);
      }
      input[type=submit]:active, .find-btn:active {
        transform: scale(0.96);
        box-shadow: 0 0 32px 4px rgba(192,57,43,0.5);
        background: #922b21;
      }
      input[type=submit].shuffle-btn:hover {
        background: rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.8);
        border-color: rgba(255,255,255,0.2);
      }

      .movie-card {
        background: rgba(255,255,255,0.03);
        border: 0.5px solid rgba(255,255,255,0.07);
        border-radius: 10px;
        padding: 16px;
        margin-bottom: 12px;
        display: flex;
        gap: 14px;
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.4s ease, transform 0.4s ease, border-color 0.2s ease, background 0.2s ease;
      }
      .movie-card:hover {
        background: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.12);
      }
      .movie-card.visible { opacity: 1; transform: translateY(0); }
      .card-strip {
        width: 3px;
        min-height: 60px;
        border-radius: 2px;
        background: rgba(192,57,43,0.4);
        flex-shrink: 0;
        transition: background 0.2s ease;
      }
      .movie-card:hover .card-strip { background: rgba(192,57,43,0.75); }

      .mood-pill {
        background: rgba(255,255,255,0.07);
        border: 0.5px solid rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.6);
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        display: inline-block;
        transform: scale(0.8);
        opacity: 0;
        transition: transform 0.3s ease, opacity 0.3s ease;
      }
      .mood-pill.pop { transform: scale(1); opacity: 1; }

      .mood-row {
        font-size: 12px;
        color: rgba(255,255,255,0.3);
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        opacity: 0;
        transform: translateY(8px);
        transition: opacity 0.4s ease, transform 0.4s ease;
      }
      .mood-row.visible { opacity: 1; transform: translateY(0); }

      .section-title-animated {
        font-size: 18px;
        font-weight: 500;
        color: #fff;
        margin-bottom: 16px;
        opacity: 0;
        transform: translateY(8px);
        transition: opacity 0.4s ease 0.1s, transform 0.4s ease 0.1s;
      }
      .section-title-animated.visible { opacity: 1; transform: translateY(0); }

      @keyframes ripple { to { transform: scale(4); opacity: 0; } }
    </style>
  </head>

  <body>
    <div id="cursor">🎬</div>

    <nav>
      <div style="display: flex; align-items: center; gap: 10px;">
        <span style="font-size: 18px;">🎬</span>
        <span style="font-size: 22px; font-weight: 700; color: #fff; letter-spacing: -0.5px;">Gamvie</span>
        <span style="font-size: 11px; background: rgba(192,57,43,0.2); color: #e07060; border: 0.5px solid rgba(192,57,43,0.3); border-radius: 4px; padding: 2px 6px; letter-spacing: 0.05em;">감</span>
      </div>
    </nav>

    <%= yield %>

    <script>
      const cursor = document.getElementById('cursor');
      const emojis = ['🎬', '🎞️', '🎥', '📽️'];
      let emojiIndex = 0;

      document.addEventListener('mousemove', (e) => {
        cursor.style.left = e.clientX + 'px';
        cursor.style.top = e.clientY + 'px';
      });

      document.addEventListener('click', (e) => {
        emojiIndex = (emojiIndex + 1) % emojis.length;
        cursor.textContent = emojis[emojiIndex];

        const btn = e.target.closest('input[type=submit]');
        if (btn) {
          const ripple = document.createElement('span');
          const size = btn.offsetWidth;
          ripple.style.cssText = `
            position: absolute; border-radius: 50%;
            background: rgba(255,255,255,0.25);
            width: ${size}px; height: ${size}px;
            left: ${e.offsetX - size/2}px;
            top: ${e.offsetY - size/2}px;
            transform: scale(0);
            animation: ripple 0.5s ease-out forwards;
            pointer-events: none;
          `;
          btn.appendChild(ripple);
          setTimeout(() => ripple.remove(), 500);
        }
      });

      document.addEventListener('DOMContentLoaded', () => {
        const moodRow = document.getElementById('moodRow');
        const sectionTitle = document.getElementById('sectionTitle');
        const cards = document.querySelectorAll('.movie-card');
        const pills = document.querySelectorAll('.mood-pill');

        if (moodRow) {
          setTimeout(() => moodRow.classList.add('visible'), 100);
          setTimeout(() => sectionTitle.classList.add('visible'), 200);
          pills.forEach((p, i) => setTimeout(() => p.classList.add('pop'), 250 + i * 120));
          cards.forEach((c, i) => setTimeout(() => c.classList.add('visible'), 350 + i * 150));
        }
      });
    </script>
  </body>
</html>