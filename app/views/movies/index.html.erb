<div style="position: relative; min-height: 100vh;">
  <div style="position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 800px; height: 340px; background: radial-gradient(ellipse at 50% 0%, rgba(180,60,40,0.15) 0%, transparent 70%); pointer-events: none;"></div>

  <div style="max-width: 760px; margin: 0 auto; padding: 60px 32px 80px; position: relative;">

    <div style="font-size: 11px; letter-spacing: 0.14em; color: #c0392b; text-transform: uppercase; margin-bottom: 20px; display: flex; align-items: center; gap: 8px;">
      <div style="display: flex; gap: 3px;">
        <div class="reel-hole"></div>
        <div class="reel-hole"></div>
        <div class="reel-hole"></div>
        <div class="reel-hole"></div>
      </div>
      Now showing
    </div>

    <h1 style="font-size: 72px; font-weight: 700; color: #fff; line-height: 1; margin-bottom: 8px; letter-spacing: -2px;">What's your<br>mood<span style="color: #c0392b;">?</span></h1>
    <p style="font-size: 16px; color: rgba(255,255,255,0.35); margin-bottom: 6px;">Tell us how you're feeling and we'll find your perfect film.</p>
    <p style="font-size: 12px; color: rgba(255,255,255,0.18); letter-spacing: 0.05em; margin-bottom: 36px;">감 (gam) — feeling · vie — movie</p>

    <%= form_with url: recommend_path, method: :post do |f| %>
      <div class="mood-input-box">
        <%= f.text_area :mood_input,
            placeholder: "e.g. I just got rejected, need background vibes, just bored...",
            rows: 3 %>
      </div>
      <%= f.submit "▶ Find My Movies" %>
    <% end %>

    <div style="display: flex; gap: 32px; margin-top: 40px; padding-top: 28px; border-top: 0.5px solid rgba(255,255,255,0.05);">
      <div>
        <div style="font-size: 22px; font-weight: 700; color: #fff; margin-bottom: 2px;">100+</div>
        <div style="font-size: 11px; color: rgba(255,255,255,0.25); letter-spacing: 0.08em; text-transform: uppercase;">Films</div>
      </div>
      <div>
        <div style="font-size: 22px; font-weight: 700; color: #fff; margin-bottom: 2px;">150+</div>
        <div style="font-size: 11px; color: rgba(255,255,255,0.25); letter-spacing: 0.08em; text-transform: uppercase;">Keywords</div>
      </div>
      <div>
        <div style="font-size: 22px; font-weight: 700; color: #fff; margin-bottom: 2px;">1</div>
        <div style="font-size: 11px; color: rgba(255,255,255,0.25); letter-spacing: 0.08em; text-transform: uppercase;">Search</div>
      </div>
    </div>

    <% if @movies.present? %>
      <div style="margin-top: 56px;">
        <div class="mood-row" id="moodRow">
          Detected mood:
          <% @detected_moods.each do |mood| %>
            <span class="mood-pill"><%= mood %></span>
          <% end %>
        </div>

        <h2 class="section-title-animated" id="sectionTitle">We think you'd like...</h2>

        <% @movies.each do |movie| %>
          <div class="movie-card">
            <div class="card-strip"></div>
            <% if movie.poster_url.present? %>
              <img src="<%= movie.poster_url %>"
                   alt="<%= movie.title %>"
                   style="width: 70px; height: 105px; border-radius: 6px; object-fit: cover; flex-shrink: 0;">
            <% end %>
            <div style="flex: 1;">
              <h3 style="font-size: 15px; font-weight: 500; color: #fff; margin-bottom: 4px;"><%= movie.title %></h3>
              <p style="font-size: 12px; color: rgba(255,255,255,0.3); margin-bottom: 8px;"><%= movie.genre %> · ⭐ <%= movie.rating %></p>
              <p style="font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 12px;"><%= movie.description %></p>
              <%= link_to "🔍 Learn more →",
                  "https://www.google.com/search?q=#{CGI.escape(movie.title + ' movie')}",
                  target: "_blank",
                  style: "font-size: 12px; color: #c0392b; text-decoration: none;" %>
            </div>
          </div>
        <% end %>

        <div style="margin-top: 20px; text-align: center;">
          <%= form_with url: recommend_path, method: :post do |f| %>
            <%= f.hidden_field :mood_input, value: @input %>
            <%= f.hidden_field :shuffle, value: "true" %>
            <%= f.submit "↻ Not feeling this? Try different picks",
                style: "background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.3); border: 0.5px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 10px 20px; font-size: 13px; cursor: none; transition: all 0.2s ease;" %>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>
</div>