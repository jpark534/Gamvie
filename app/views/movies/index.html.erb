<div style="position: relative; min-height: 100vh;">
  <div style="position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 700px; height: 280px; background: radial-gradient(ellipse at 50% 0%, rgba(180,60,40,0.13) 0%, transparent 70%); pointer-events: none;"></div>

  <div style="max-width: 700px; margin: 0 auto; padding: 48px 24px 60px; position: relative;">

    <div style="font-size: 11px; letter-spacing: 0.12em; color: #c0392b; text-transform: uppercase; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
      <div style="display: flex; gap: 3px;">
        <div class="reel-hole"></div>
        <div class="reel-hole"></div>
        <div class="reel-hole"></div>
        <div class="reel-hole"></div>
      </div>
      Now showing
    </div>

    <h1 style="font-size: 28px; font-weight: 500; color: #fff; margin-bottom: 8px;">What's your mood tonight?</h1>
    <p style="color: rgba(255,255,255,0.35); font-size: 15px; margin-bottom: 32px;">Tell us how you're feeling and we'll find your perfect film.</p>

    <%= form_with url: recommend_path, method: :post, data: { turbo: false } do |f| %>
      <div class="mood-input-box">
        <%= f.text_area :mood_input,
            placeholder: "e.g. I just got rejected, I'm studying and need background vibes, something like Interstellar but happier...",
            rows: 3 %>
      </div>
      <%= f.submit "▶ Find My Movies" %>
    <% end %>

    <% if @movies.present? %>
      <div style="margin-top: 40px;">
        <div class="mood-row" id="moodRow">
          Detected mood:
          <% @detected_moods.each do |mood| %>
            <span class="mood-pill"><%= mood %></span>
          <% end %>
        </div>

        <h2 class="section-title-animated" id="sectionTitle">We think you'd like...</h2>

        <% @movies.each do |movie| %>
          <div class="movie-card">
            <div class="card-strip"></div>
            <% if movie.poster_url.present? %>
              <img src="<%= movie.poster_url %>"
                  alt="<%= movie.title %>"
                  style="width: 70px; height: 105px; border-radius: 6px; object-fit: cover; flex-shrink: 0;">
            <% end %>
            <div style="flex: 1;">
              <h3 style="font-size: 15px; font-weight: 500; color: #fff; margin-bottom: 4px;"><%= movie.title %></h3>
              <p style="font-size: 12px; color: rgba(255,255,255,0.3); margin-bottom: 8px;"><%= movie.genre %> · ⭐ <%= movie.rating %></p>
              <p style="font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 12px;"><%= movie.description %></p>
              <%= link_to "🔍 Learn more →",
                  "https://www.google.com/search?q=#{CGI.escape(movie.title + ' movie')}",
                  target: "_blank",
                  style: "font-size: 12px; color: #c0392b; text-decoration: none;" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

  </div>
</div>